# nuocode 配置示例。复制为 .nuocode/config.yaml 后填入真实 api_key。
# providers 是一个列表；当只有 1 项时启动直接进入对话，多项时呈现选择列表。

providers:
  - name: claude-sonnet
    protocol: anthropic
    api_key: sk-ant-REPLACE_ME
    model: claude-sonnet-4-20250514
    thinking: true
    # base_url: https://api.anthropic.com  # 默认即可，留空使用 SDK 默认端点

  # - name: gpt-4o
  #   protocol: openai
  #   api_key: sk-REPLACE_ME
  #   model: gpt-4o
  #   # base_url: https://api.openai.com/v1
  #   # thinking 字段对 openai 协议无效（忽略）
